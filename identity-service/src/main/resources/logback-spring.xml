<?xml version="1.0" encoding="UTF-8"?>
<!--
    BizLedger — Structured JSON Logging Configuration (Identity Service)
    ─────────────────────────────────────────────────────────────────────
    Same pattern as API Gateway: JSON per line, MDC-enriched with traceId,
    userId, tenantId — injected by AuditInterceptor and JwtAuthFilter.
-->
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"identity-service-java","environment":"local"}</customFields>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>tenantId</includeMdcKeyName>
            <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerCause>10</maxDepthPerCause>
                <rootCauseFirst>true</rootCauseFirst>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- Local Developer Console appender with ANSI coloring -->
    <appender name="CONSOLE_COLOR" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(---){faint} %clr([%15.15t]){faint} %clr([%X{traceId:-}]){yellow} %clr([%X{userId:-}]){green} %clr([%X{tenantId:-}]){blue} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Local/Dev console output (friendly in IntelliJ) -->
    <springProfile name="!docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE_COLOR"/>
        </root>
    </springProfile>


    <!-- Container JSON console output (ELK, logstash parseable) -->
    <springProfile name="docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>


    <logger name="com.netflix.eureka" level="WARN"/>
    <logger name="com.netflix.discovery" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="com.overcode250204" level="DEBUG"/>

</configuration>
